# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js (DIUBAH: .next/ dihapus dari daftar ignore agar bisa diupload ke hosting)
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (DIPERKETAT: Memastikan kredensial database Supabase tidak bocor ke GitHub)
.env*.local
.env.development
.env.production

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Mengabaikan file pelamar agar tidak masuk ke GitHub (PENTING untuk keamanan server)
/public/uploads/*
!.gitkeep